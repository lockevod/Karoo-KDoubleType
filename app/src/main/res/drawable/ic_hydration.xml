<?xml version="1.0" encoding="utf-8"?>
<!--
  Bidón de ciclista (origen: KSafe). Silueta blanca monocroma: los campos la tintan
  en runtime vía ColorFilter.tint (SRC_IN), así que cualquier detalle por alpha
  desaparecería — por eso es silueta plana (boquilla + cuello + cuerpo), sin la
  banda de etiqueta del original.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Boquilla push-pull -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M10.5,1.5 L13.5,1.5 L13.5,3 L10.5,3 Z" />

    <!-- Cuello, más estrecho que el cuerpo para que se lea como bidón -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M9.5,3 L14.5,3 L14.5,5 L9.5,5 Z" />

    <!-- Cuerpo: hombros redondeados, lados rectos, base redondeada -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M9.5,5 L14.5,5 A2,2 0 0 1 16.5,7 L16.5,20.5 A1.5,1.5 0 0 1 15,22 L9,22 A1.5,1.5 0 0 1 7.5,20.5 L7.5,7 A2,2 0 0 1 9.5,5 Z" />
</vector>
